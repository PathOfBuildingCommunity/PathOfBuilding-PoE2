<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
  "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <!-- LuaJIT generates and executes machine code at runtime. Under the
       hardened runtime (required for notarization) it would be killed without
       these. allow-jit enables MAP_JIT; allow-unsigned-executable-memory
       covers LuaJIT's non-MAP_JIT code paths. -->
  <key>com.apple.security.cs.allow-jit</key>
  <true/>
  <key>com.apple.security.cs.allow-unsigned-executable-memory</key>
  <true/>
  <!-- The app loads bundled third-party dylibs (SDL3, LuaJIT, curl, ...);
       allow them to load even though they are not part of the main binary. -->
  <key>com.apple.security.cs.disable-library-validation</key>
  <true/>
</dict>
</plist>
